# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=nyubites
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nyubites
DATABASE_URL=postgresql+asyncpg://nyubites:changeme@db:5432/nyubites

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=supersecretkey-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI (Groq preferred — free tier at console.groq.com) ──────────────────────
GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...   # fallback if Groq key is empty

# ── Google Places ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...

# ── Auth token TTLs ───────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
VERIFICATION_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_MINUTES=60

# ── Email ─────────────────────────────────────────────────────────────────────
# Set to "smtp" in production; "console" prints emails to stdout (dev default)
EMAIL_BACKEND=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_ADDRESS=noreply@nyubites.com
EMAIL_FROM_NAME=NYU Bites

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
